{
  "ReverseProxy": {
    "Routes": {
      "orders-route": {
        "ClusterId": "orders-cluster",
        "Match": { "Path": "/api/orders/{**catch-all}" }
      },
      "products-route": {
        "ClusterId": "products-cluster",
        "Match": { "Path": "/api/products/{**catch-all}" }
      },
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": { "Path": "/api/auth/{**catch-all}" }
      },
      "payments-route": {
        "ClusterId": "payments-cluster",
        "Match": { "Path": "/api/payments/{**catch-all}" }
      },
      "jwks-route": {
        "ClusterId": "auth-cluster",
        "Match": { "Path": "/.well-known/jwks.json" }
      },

      "swagger-auth-json": {
        "ClusterId": "auth-cluster",
        "Match": { "Path": "/docs/auth/swagger.json" },
        "Transforms": [ { "PathSet": "/swagger/v1/swagger.json" } ]
      },
      "swagger-orders-json": {
        "ClusterId": "orders-cluster",
        "Match": { "Path": "/docs/orders/swagger.json" },
        "Transforms": [ { "PathSet": "/swagger/v1/swagger.json" } ]
      },
      "swagger-products-json": {
        "ClusterId": "products-cluster",
        "Match": { "Path": "/docs/products/swagger.json" },
        "Transforms": [ { "PathSet": "/swagger/v1/swagger.json" } ]
      },
      "swagger-payments-json": {
        "ClusterId": "payments-cluster",
        "Match": { "Path": "/docs/payments/swagger.json" },
        "Transforms": [ { "PathSet": "/swagger/v1/swagger.json" } ]
      },

      "health-auth": {
        "ClusterId": "auth-cluster",
        "Match": { "Path": "/health/auth" },
        "Transforms": [ { "PathSet": "/health" } ]
      },
      "health-orders": {
        "ClusterId": "orders-cluster",
        "Match": { "Path": "/health/orders" },
        "Transforms": [ { "PathSet": "/health" } ]
      },
      "health-products": {
        "ClusterId": "products-cluster",
        "Match": { "Path": "/health/products" },
        "Transforms": [ { "PathSet": "/health" } ]
      },
      "health-payments": {
        "ClusterId": "payments-cluster",
        "Match": { "Path": "/health/payments" },
        "Transforms": [ { "PathSet": "/health" } ]
      }
    },
    "Clusters": {
      "orders-cluster": {
        "Destinations": {
          "orders-service": { "Address": "http://orders-service:8080/" }
        }
      },
      "products-cluster": {
        "Destinations": {
          "products-service": { "Address": "http://products-service:8080/" }
        }
      },
      "auth-cluster": {
        "Destinations": {
          "auth-service": { "Address": "http://auth-service:8080/" }
        }
      },
      "payments-cluster": {
        "Destinations": {
          "payments-service": { "Address": "http://payments-service:8080/" }
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
